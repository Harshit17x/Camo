<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/overlay_root"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="0dp"
    android:background="@android:color/transparent"
    tools:ignore="HardcodedText">

    <!-- Card Container -->
    <LinearLayout
        android:id="@+id/card_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginTop="48dp"
        android:orientation="vertical"
        android:padding="24dp"
        android:elevation="24dp"
        android:background="@drawable/overlay_card_bg">

        <!-- Header Row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="16dp">

            <!-- Pulsing indicator dot -->
            <View
                android:id="@+id/pulse_dot"
                android:layout_width="10dp"
                android:layout_height="10dp"
                android:background="@drawable/green_dot"
                android:layout_marginEnd="10dp" />

            <TextView
                android:id="@+id/label_new_request"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="NEW RIDE REQUEST"
                android:textColor="#10B981"
                android:textSize="11sp"
                android:textStyle="bold"
                android:letterSpacing="0.15"
                android:fontFamily="sans-serif-black" />

            <TextView
                android:id="@+id/text_fare"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="₹0"
                android:textColor="#18181B"
                android:textSize="26sp"
                android:textStyle="bold"
                android:fontFamily="sans-serif-black" />
        </LinearLayout>

        <TextView
            android:id="@+id/text_ride_type"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Economy Cab"
            android:textColor="#3F3F46"
            android:textSize="18sp"
            android:textStyle="bold"
            android:fontFamily="sans-serif-medium"
            android:layout_marginBottom="4dp" />

        <TextView
            android:id="@+id/text_distance"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text=""
            android:textColor="#A1A1AA"
            android:textSize="12sp"
            android:fontFamily="sans-serif"
            android:layout_marginBottom="20dp" />

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#F4F4F5"
            android:layout_marginBottom="16dp" />

        <!-- Pickup -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="12dp">

            <View
                android:layout_width="8dp"
                android:layout_height="8dp"
                android:background="@drawable/green_dot"
                android:layout_marginEnd="12dp" />

            <TextView
                android:id="@+id/text_pickup"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Pickup location"
                android:textColor="#71717A"
                android:textSize="13sp"
                android:maxLines="2"
                android:ellipsize="end"
                android:fontFamily="sans-serif-medium" />
        </LinearLayout>

        <!-- Connector line -->
        <View
            android:layout_width="1dp"
            android:layout_height="16dp"
            android:background="#E4E4E7"
            android:layout_marginStart="3dp"
            android:layout_marginBottom="4dp" />

        <!-- Dropoff -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="24dp">

            <View
                android:layout_width="8dp"
                android:layout_height="8dp"
                android:background="@drawable/red_dot"
                android:layout_marginEnd="12dp" />

            <TextView
                android:id="@+id/text_dropoff"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Dropoff location"
                android:textColor="#18181B"
                android:textSize="13sp"
                android:maxLines="2"
                android:ellipsize="end"
                android:fontFamily="sans-serif-medium" />
        </LinearLayout>

        <!-- Action Buttons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center">

            <TextView
                android:id="@+id/btn_reject"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                android:gravity="center"
                android:text="REJECT"
                android:textColor="#A1A1AA"
                android:textSize="13sp"
                android:textStyle="bold"
                android:letterSpacing="0.1"
                android:fontFamily="sans-serif-black"
                android:background="@drawable/btn_reject_bg" />

            <TextView
                android:id="@+id/btn_accept"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:gravity="center"
                android:text="ACCEPT"
                android:textColor="#FFFFFF"
                android:textSize="13sp"
                android:textStyle="bold"
                android:letterSpacing="0.1"
                android:fontFamily="sans-serif-black"
                android:background="@drawable/btn_accept_bg" />
        </LinearLayout>

        <!-- Timer Bar -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="4dp"
            android:layout_marginTop="20dp"
            android:background="@drawable/timer_track_bg">

            <View
                android:id="@+id/timer_bar"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/timer_fill_bg" />
        </FrameLayout>

    </LinearLayout>

</LinearLayout>
